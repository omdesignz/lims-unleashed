{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "carlos-meneses/laravel-mpdf": "^2.1",
        "chrome-php/chrome": "^1.15",
        "diglactic/laravel-breadcrumbs": "^10.0.0",
        "endroid/qr-code": "^6.1",
        "guzzlehttp/guzzle": "^7.2",
        "highsolutions/eloquent-sequence": "^3.12",
        "inertiajs/inertia-laravel": "^3.0",
        "jenssegers/agent": "^2.6",
        "kalnoy/nestedset": "^7.0",
        "kwn/number-to-words": "^2.6",
        "laravel-notification-channels/microsoft-teams": "^2.2",
        "laravel-notification-channels/telegram": "^7.0",
        "laravel-notification-channels/twilio": "^4.2",
        "laravel/fortify": "^1.21",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.15",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0",
        "league/csv": "^9.23",
        "maatwebsite/excel": "^3.1",
        "mpdf/qrcode": "^1.2",
        "phpoffice/phpword": "^1.3",
        "predis/predis": "^2.2",
        "socialiteproviders/microsoft": "^4.9",
        "socialiteproviders/microsoft-azure": "^5.2",
        "spatie/array-to-xml": "^3.1",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-backup": "^10.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-passkeys": "^1.7",
        "spatie/laravel-pdf": "^2.6",
        "spatie/laravel-permission": "^6.9",
        "spatie/laravel-query-builder": "^6.0",
        "spatie/laravel-settings": "^3.3",
        "tightenco/ziggy": "^2.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.16",
        "laravel/sail": "^1.30",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^12.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/BarcodeHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
